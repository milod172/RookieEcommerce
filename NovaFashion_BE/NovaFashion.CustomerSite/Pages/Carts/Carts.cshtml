@page "/cart"
@model NovaFashion.CustomerSite.Pages.Carts.CartsModel

@{
}

<div class="container py-5">
    <div class="row gx-5">
        <div class="col-lg-8">
            <h1 class="cart-page-title">Giỏ hàng</h1>
            <div class="cart-item-count" id="cart-item-count"></div>
            <hr class="cart-divider" />
            <div id="cart-list"></div>
            <div id="cart-empty" class="text-start d-none">
                <p>Giỏ hàng trống.</p>
                <a asp-page="/Products/Products" class="btn btn-dark">Tiếp tục mua sắm</a>
            </div>
        </div>

        <div class="col-lg-4 mt-5 mt-lg-0">
            <div class="cart-summary-card">
                <h2>Tổng đơn hàng</h2>
                <div class="cart-summary-row">
                    <span><strong>Tạm tính</strong></span>
                    <span><strong id="cart-subtotal">0 đ</strong></span>
                </div>
                <hr class="cart-divider my-2" />
                <div class="cart-summary-row cart-summary-total">
                    <span>Tổng cộng</span>
                    <span id="cart-total">0 đ</span>
                </div>
                <button class="cart-btn-purchase" onclick="handleCheckout()">
                     Mua hàng
                </button>
            </div>
        </div>

        <div id="empty-cart-toast"
             class="cart-toast d-none">
            Giỏ hàng trống, vui lòng thêm sản phẩm vào giỏ hàng
        </div>

        <div id="stock-error-toast"
             class="cart-toast d-none">

            Một số sản phẩm đã vượt quá số lượng tồn kho,
            vui lòng kiểm tra lại giỏ hàng

        </div>
    </div>
</div>

@section Scripts {
    <script>

        let cartItemsCache = [];

        async function renderCart() {
            const localItems = CartService.getItems();
            const listEl     = document.getElementById("cart-list");
            const emptyEl    = document.getElementById("cart-empty");
            const countEl    = document.getElementById("cart-item-count");
            const subtotalEl = document.getElementById("cart-subtotal");
            const totalEl    = document.getElementById("cart-total");
            const checkoutBtn = document.querySelector(".cart-btn-purchase");

            // Empty cart
            if (localItems.length === 0) {

                cartItemsCache = [];

                listEl.innerHTML = "";

                emptyEl.classList.remove("d-none");

                countEl.textContent = "";

                subtotalEl.textContent = formatCurrency(0);
                totalEl.textContent    = formatCurrency(0);

                return;
            }

            // Load cart from server
            const response = await fetch("?handler=LoadCart", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(localItems)
            });

            // API error
            if (!response.ok) {

                listEl.innerHTML =
                    `<p class="text-danger">Lỗi tải giỏ hàng.</p>`;

                checkoutBtn.disabled = true;

                return;
            }

            const items = await response.json();

            // Cache current server validated items
            cartItemsCache = items;

            // Check invalid stock
            const hasInvalidItems = items.some(
                x => x.is_exceed_stock || !x.is_available
            );

            // Disable checkout
            checkoutBtn.disabled = hasInvalidItems;

            // Optional text change
            checkoutBtn.textContent = hasInvalidItems
                ? "Vui lòng kiểm tra giỏ hàng"
                : "Mua hàng";

            emptyEl.classList.add("d-none");

            countEl.textContent =
                `${items.length} sản phẩm`;

            // Render items
            listEl.innerHTML = items.map(item => `

                <div
                    class="d-flex gap-4 mb-4"
                    id="row-${item.product_variant_id}"
                >

                    <div class="cart-product-img">
                        <a href="/Products/ProductDetails/${item.product_id}">
                            <img
                                src="${item.image_url}"
                                alt="${item.product_name}"
                            >
                        </a>
                    </div>

                    <div class="flex-grow-1">

                        <div class="d-flex justify-content-between align-items-start">

                            <div>

                                <div class="cart-brand">
                                    <a href="/Products/ProductDetails/${item.product_id}">
                                        ${item.product_name}
                                    </a>
                                </div>

                                <div class="cart-product-name">
                                    ${item.sku}
                                </div>

                            </div>

                            <button
                                class="cart-btn-remove"
                                onclick="removeItem('${item.product_variant_id}')"
                            >
                                ✕
                            </button>

                        </div>

                        <div class="cart-meta">
                            <strong>Size: ${item.size}</strong>
                        </div>

                        <div class="cart-stock-quantity
                            ${item.available_stock <= 5 ? "low-stock" : ""}">
    
                            Còn lại: ${item.available_stock} sản phẩm

                        </div>

                        ${
                            !item.is_available
                            ? `
                                <div class="cart-stock-error">
                                    Sản phẩm hiện không khả dụng
                                </div>
                              `
                            : ""
                        }

                       

                        <div class="d-flex align-items-center gap-3 mb-2">

                            <div
                                class="cart-qty-control"
                                data-price="${item.unit_price}"
                                data-id="${item.product_variant_id}"
                            >

                                <button
                                    type="button"
                                    onclick="changeQty(this, -1)"
                                >
                                    −
                                </button>

                                <span class="cart-qty-value">
                                    ${item.quantity}
                                </span>

                                <button
                                    type="button"
                                    onclick="changeQty(this, 1)"
                                    ${item.quantity >= item.available_stock
                                        || !item.is_available
                                        ? "disabled"
                                        : ""}
                                >
                                    +
                                </button>

                            </div>

                            <span
                                class="cart-price mb-0"
                                data-line-total
                            >
                                ${formatCurrency(item.total_price)}
                            </span>

                        </div>

                    </div>

                </div>

            `).join("");

            // Total
            const grandTotal = items.reduce(
                (sum, x) => sum + x.total_price,
                0
            );

            subtotalEl.textContent =
                formatCurrency(grandTotal);

            totalEl.textContent =
                formatCurrency(grandTotal);
        }

        function changeQty(btn, delta) {

            const wrap = btn.parentElement;

            const productVariantId =
                wrap.dataset.id;

            if (delta > 0) {
                CartService.increase(productVariantId);
            }
            else {
                CartService.decrease(productVariantId);
            }

            renderCart();
        }

        function removeItem(productVariantId) {

            CartService.remove(productVariantId);

            renderCart();
        }

        function formatCurrency(value) {

            return new Intl.NumberFormat("vi-VN", {
                style: "currency",
                currency: "VND"
            }).format(value);
        }

        
        function handleCheckout() {

            const localItems =
                CartService.getItems();

            // Empty cart
            if (!localItems || localItems.length === 0) {

                showEmptyCartToast();

                return;
            }

            // Invalid stock
            const hasInvalidItems = cartItemsCache.some(
                x => x.is_exceed_stock || !x.is_available
            );

            if (hasInvalidItems) {

                showStockErrorToast();

                return;
            }

            // Go checkout
            window.location.href = "/checkout";
        }

        function showEmptyCartToast() {

            showToast(
                "empty-cart-toast"
            );
        }

        function showStockErrorToast() {

            showToast(
                "stock-error-toast"
            );
        }

        function showToast(id) {

            const toast =
                document.getElementById(id);

            if (!toast) return;

            toast.classList.remove("d-none");

            requestAnimationFrame(() => {
                toast.classList.add("show");
            });

            setTimeout(() => {

                toast.classList.remove("show");

                setTimeout(() => {
                    toast.classList.add("d-none");
                }, 300);

            }, 2500);
        }

        document.addEventListener(
            "DOMContentLoaded",
            renderCart
        );

    </script>
}