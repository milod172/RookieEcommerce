@using NovaFashion.SharedViewModels.CategoryDtos
@model CategoryDto

@{
    var collapseId = $"cat-{Model.Id.ToString()[..8]}";
    var currentCategoryId = ViewData["CategoryId"] as Guid?;
    var isSelected = currentCategoryId == Model.Id;
}

<li class="category-item list-unstyled">
    @if (Model.HasChildren)
    {
        <a hx-get="@Url.Page("/Products/Products")"
               hx-target="#product-container"
               hx-swap="innerHTML"
               hx-push-url="true"
               hx-include="#MinPrice, #MaxPrice, #PageSize, #SortBy, #CategoryId"
               hx-vals='{"CategoryId":"@Model.Id","PageNumber":"1"}'
               class="d-flex justify-content-between align-items-center text-decoration-none text-reset category-parent @(isSelected ? "active" : "")"
               data-bs-toggle="collapse"
               data-bs-target="#@collapseId"
               style="cursor:pointer">

            <span class="d-flex align-items-center gap-1">
                @if (isSelected)
                {
                    <span class="selected-dot"></span>
                }
                @Model.CategoryName
            </span>
           
            <i class="fa-solid fa-chevron-down"></i>
         </a>
            
     

        <ul id="@collapseId" class="list-unstyled category-children collapse">
            @foreach (var child in Model.SubCategories)
            {
                <partial name="/Pages/Categories/_CategoryNodePartial.cshtml"
                         model="child"
                         view-data="ViewData" />
            }
        </ul>
    }
    else
    {
        <a hx-get="@Url.Page("/Products/Products")"
               hx-target="#product-container"
               hx-swap="innerHTML"
               hx-push-url="true"
               hx-include="#MinPrice, #MaxPrice, #PageSize, #SortBy, #CategoryId"
               hx-vals='{"CategoryId":"@Model.Id","PageNumber":"1"}'
               class="d-flex align-items-center text-decoration-none text-reset category-parent @(isSelected ? "active" : "")">

            <span class="d-flex align-items-center gap-1">
                @if (isSelected)
                {
                    <span class="selected-dot"></span>
                }
                @Model.CategoryName
            </span>
        </a>
    }
</li>