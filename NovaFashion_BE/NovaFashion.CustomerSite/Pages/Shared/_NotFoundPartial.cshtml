@page "/not-found"
@model _NotFoundPartialModel
@{
}

<div class="not-found-body">
    <div class="nf-wrapper">
        <h1 class="nf-code">404</h1>
        <div class="nf-divider"></div>
        <h2 class="nf-title">Page Not Found</h2>
        <p class="nf-text">Trang bạn đang tìm kiếm không tồn tại hoặc đã được di chuyển.</p>
        <div class="nf-actions">
            <a asp-page="/Index" class="btn-home">Về Trang Chủ</a>
            <a href="javascript:history.back()" class="btn-back">Quay Lại</a>
        </div>
    </div>
</div>
