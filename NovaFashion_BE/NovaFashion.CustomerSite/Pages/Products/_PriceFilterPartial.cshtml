@model ProductsModel

<div class="sidebar-card">

    <div class="sidebar-title">Nhập khoảng giá</div>

    <div class="row g-2 mb-3">

        <div class="col-6">
            <label class="form-label small mb-1">Từ</label>
            <div class="input-group">
                <span class="input-group-text">đ</span>
                <input type="number"
                       id="MinPrice"
                       name="MinPrice"
                       min="0"
                       class="form-control"
                       value="@(Model.MinPrice.HasValue? Model.MinPrice: null)" />
            </div>
        </div>

        <div class="col-6">
            <label class="form-label small mb-1">Đến</label>
            <div class="input-group">
                <span class="input-group-text">đ</span>
                <input type="number"
                       id="MaxPrice"
                       name="MaxPrice"
                       min="0"
                       class="form-control"
                       value="@(Model.MaxPrice.HasValue? Model.MaxPrice: null)" />
            </div>
        </div>
    </div>

    <div asp-validation-summary="All" class="text-danger small mb-2"></div>

    <button type="button"
            class="btn-filter w-100"
            hx-get="/shop?handler=Filter"
            hx-target="#product-container"
            hx-swap="innerHTML"
            hx-push-url="true"
            hx-include="#MinPrice, #MaxPrice, #PageSize, #SortBy, #PageNumber, #CategoryId">
        Áp dụng
    </button>
</div>