@page "{id:Guid}"
@model ProductDetailsModel
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="container-fluid px-md-5">
    <div class="row">
        <div class="col-lg-8 col-md-12">
            <div class="row g-2">
                <div class="col-md-6">
                    <img src="@Model.Product.Images.FirstOrDefault()?.ImageUrl"
                         alt="@Model.Product.Images.FirstOrDefault()?.AltText" class="product-image">
                </div>
                <div class="col-md-6">
                    <img src="@Model.Product.Images.Skip(1).FirstOrDefault()?.ImageUrl"
                         alt="@Model.Product.Images.Skip(1).FirstOrDefault()?.AltText" class="product-image">
                </div>
            </div>
        </div>

        <div class="col-lg-4 col-md-12 ps-lg-5 pt-md-5">
            <h1 class="product-brand">@Model.Product.ProductName</h1>
            <p class="product-name">@Model.Product.Description</p>
            <div class="price" id="product-price">@Model.Product.UnitPrice?.ToString("N0") đ</div>

            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="size-label mb-0">Size:</span>
            </div>

            <div class="size-grid">
                @foreach (var item in Model.Product.Variants)
                {
                    <div class="size-item"
                         data-price="@item.UnitPrice"
                         data-id="@item.Id"
                         data-stock="@item.StockQuantity"
                         onclick="selectVariant(this)">
                        @item.Size
                    </div>
                }
            </div>
            <p id="stock-info" class="small mt-1 text-muted"></p>

            <p id="size-error" class="text-danger small mt-1 d-none">Vui lòng chọn kích thước.</p>

            <button class="btn btn-add-cart" onclick="addToCart()">Thêm vào giỏ hàng</button>

            <div class="description-header">
                <span>Chi tiết sản phẩm</span>
            </div>
            <div class="description-content">
                "@Model.Product.Details"
            </div>
        </div>
    </div>

    <div id="toast-success" class="toast-success d-none">
        Thêm sản phẩm vào giỏ hàng thành công
    </div>
</div>

@section Scripts {
    <script>
        let selectedVariantId = null;
        let selectedStock = 0;

        const IS_AUTHENTICATED = @Json.Serialize(User.Identity?.IsAuthenticated == true);

        function selectVariant(el) {
            document.querySelectorAll(".size-item").forEach(x => x.classList.remove("active"));
            el.classList.add("active");

            selectedVariantId = el.dataset.id;

            const price = parseFloat(el.dataset.price);
            selectedStock = parseInt(el.dataset.stock);

            document.getElementById("product-price").textContent =
                price.toLocaleString("vi-VN") + " đ";

            document.getElementById("stock-info").textContent =`Còn lại: ${selectedStock} sản phẩm`;

            document.getElementById("size-error").classList.add("d-none");

            const btn = document.querySelector(".btn-add-cart");

            if (selectedStock <= 0) {
                btn.disabled = true;
                btn.textContent = "Hết hàng";
            } else {
                btn.disabled = false;
                btn.textContent = "Thêm vào giỏ hàng";
            }
        }

        function addToCart() {
            if (!IS_AUTHENTICATED) {
                window.location.href = `/login?returnUrl=${encodeURIComponent(window.location.pathname)}`;
                return;
            }

            if (!selectedVariantId) {
                document.getElementById("size-error").classList.remove("d-none");
                return;
            }

            const items = CartService.getItems();
            const existing = items.find(x => x.product_variant_id === selectedVariantId);

            const currentQty = existing ? existing.quantity : 0;

            if (currentQty + 1 > selectedStock) {
                alert("Không thể thêm vượt quá số lượng tồn kho");
                return;
            }

            CartService.add(selectedVariantId, 1);
            showToast();
        }

        function showToast() {
            const toast = document.getElementById("toast-success");
            toast.classList.remove("d-none");
        
            requestAnimationFrame(() => toast.classList.add("show"));

            setTimeout(() => {
                toast.classList.remove("show");
                setTimeout(() => toast.classList.add("d-none"), 300);
            }, 2500);
        }

    </script>
}