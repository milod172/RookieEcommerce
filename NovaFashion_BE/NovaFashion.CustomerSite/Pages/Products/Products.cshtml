@page
@model ProductsModel
@{
    ViewData["Title"] = "Mua sắm";
}

<div class="container py-5">
    <div class="row g-4">

        <!-- Sidebar -->
        <aside class="col-lg-3">
            <div class="sidebar-card">
                <div class="sidebar-title">Nhập khoảng giá</div>

                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="form-label small mb-1">Từ</label>
                        <div class="input-group">
                            <span class="input-group-text">đ</span>
                            <input type="number"
                                   id="MinPrice"
                                   name="MinPrice"
                                   min="0"
                                   class="form-control"
                                   placeholder="0"
                                   value="@(Model.MinPrice.HasValue ? Model.MinPrice : null)" />
                        </div>
                    </div>
                    <div class="col-6">
                        <label class="form-label small mb-1">Đến</label>
                        <div class="input-group">
                            <span class="input-group-text">đ</span>
                            <input type="number"
                                   id="MaxPrice"
                                   name="MaxPrice"
                                   min="0"
                                   class="form-control"
                                   placeholder="0"
                                   value="@(Model.MaxPrice.HasValue ? Model.MaxPrice : null)" />
                        </div>
                    </div>
                </div>

                <!-- FIX: thêm hx-on để bắt lỗi 400 từ server -->
                <button type="button"
                        class="btn-filter w-100"
                        hx-get="@Url.Page("/Products/Products")"
                        hx-target="#product-container"
                        hx-swap="innerHTML"
                        hx-push-url="true"
                        hx-include="#MinPrice, #MaxPrice, #PageSize, #SortBy, #PageNumber"
                        hx-on:htmx:response-error="document.getElementById('price-error').textContent = 'Khoảng giá không hợp lệ'">
                    Áp dụng
                </button>

                <!-- FIX: error message placeholder -->
                <div id="price-error" class="text-danger small mt-2"></div>
            </div>
        </aside>

        <!-- Main -->
        <main class="col-lg-9">
            <div class="toolbar">
                <div class="d-flex align-items-center gap-3 flex-wrap">

                    <div>
                        <label>Hiển thị:</label>
                        <select id="PageSize"
                                name="PageSize"
                                class="form-select form-select-sm"
                                hx-get="@Url.Page("/Products/Products")"
                                hx-target="#product-container"
                                hx-swap="innerHTML"
                                hx-push-url="true"
                                hx-include="#MinPrice, #MaxPrice, #SortBy, #PageNumber"
                                hx-trigger="change">
                            
                            <option value="5" selected="@(Model.PageSize == 5 ? "selected" : null)">5</option>
                            <option value="10" selected="@(Model.PageSize == 10 ? "selected" : null)">10</option>
                            <option value="20" selected="@(Model.PageSize == 20 ? "selected" : null)">20</option>
                        </select>
                    </div>

                    <div>
                        <label>Sắp xếp:</label>
                        <select id="SortBy"
                                name="SortBy"
                                class="form-select form-select-sm"
                                hx-get="@Url.Page("/Products/Products")"
                                hx-target="#product-container"
                                hx-swap="innerHTML"
                                hx-push-url="true"
                                hx-include="#MinPrice, #MaxPrice, #PageSize, #PageNumber"
                                hx-trigger="change">
                            <option value="Newest" selected="@(Model.SortBy == "Newest" ? "selected" : null)">Mới nhất</option>
                            <option value="NameAsc" selected="@(Model.SortBy == "NameAsc" ? "selected" : null)">Tên A → Z</option>
                            <option value="NameDesc" selected="@(Model.SortBy == "NameDesc" ? "selected" : null)">Tên Z → A</option>
                        </select>
                    </div>

                </div>
            </div>

            <div class="row g-4">
                <div class="row">

                    <!-- FIX: bỏ comment, hidden input này bắt buộc phải có -->
                    <input type="hidden" id="PageNumber" name="PageNumber" value="1" />

                    <div id="product-container">
                        @await Html.PartialAsync("_ProductListPartial", Model)
                    </div>

                </div>
            </div>
        </main>
    </div>
</div>