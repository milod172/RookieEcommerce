@model ProductsModel

@{
    var currentPage = Model.Products.PageNumber;
    var totalCount = Model.Products.TotalCount;
    var pageSize = Model.Products.PageSize;
    var totalPages = Model.Products.TotalPages;

    int startIdx = totalCount == 0 ? 0 : (currentPage - 1) * pageSize + 1;
    int endIdx = Math.Min(currentPage * pageSize, totalCount);

    List<object> pageNumbers = new();
    int delta = 2;
    int left = Math.Max(1, currentPage - delta);
    int right = Math.Min(totalPages, currentPage + delta);

    if (left > 1)
    {
        pageNumbers.Add(1);
        if (left > 2) pageNumbers.Add("...");
    }
    for (int i = left; i <= right; i++)
        pageNumbers.Add(i);
    if (right < totalPages)
    {
        if (right < totalPages - 1) pageNumbers.Add("...");
        pageNumbers.Add(totalPages);
    }
}

<div class="d-flex flex-wrap justify-content-between align-items-center mt-3 gap-2">
    <small class="text-muted">
        Hiển thị <strong>@startIdx</strong>–<strong>@endIdx</strong> trong
        <strong>@totalCount</strong> sản phẩm
    </small>

    
    <input type="hidden" id="PageNumber" name="PageNumber" value="@currentPage" />

    <nav>
        <ul class="pagination pagination-sm mb-0">

            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                <a class="page-link"
                   hx-get="/shop"      
                   hx-target="#product-container"
                   hx-swap="innerHTML show:window:top"
                   hx-push-url="true"
                   hx-include="#SortBy, #MinPrice, #MaxPrice, #CategoryId, #PageSize"
                   hx-vals='{"PageNumber": "@(currentPage - 1)"}'
                   cursor: pointer
                  >‹</a>
            </li>

            @foreach (var n in pageNumbers)
            {
                if (n is string)
                {
                    <li class="page-item disabled">
                        <span class="page-link">…</span>
                    </li>
                }
                else
                {
                    var p = (int)n;
                    <li class="page-item @(currentPage == p ? "active" : "")">
                        <a class="page-link"
                           hx-get="/shop"
                           hx-target="#product-container"
                           hx-push-url="true"
                           hx-swap="innerHTML show:window:top"
                           hx-include="#SortBy, #MinPrice, #MaxPrice, #CategoryId, #PageSize"
                           hx-vals='{"PageNumber": "@p"}'
                           >@p</a>
                    </li>
                }
            }

            <li class="page-item @(currentPage >= totalPages || totalPages == 0 ? "disabled" : "")">
                <a class="page-link"
                   hx-get="/shop"         
                   hx-target="#product-container"
                   hx-push-url ="true"
                   hx-swap="innerHTML show:window:top"
                   hx-include="#SortBy, #MinPrice, #MaxPrice, #CategoryId, #PageSize"
                   hx-vals='{"PageNumber": "@(currentPage + 1)"}'
                   >›</a>
            </li>

        </ul>
    </nav>
</div>