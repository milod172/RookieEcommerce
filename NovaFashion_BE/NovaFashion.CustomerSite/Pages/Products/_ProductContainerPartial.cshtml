@model ProductsModel

<div class="container py-5">
    <div class="row g-4">
        <!-- Filter Sidebar -->
        <aside class="col-lg-3">

            <input type="hidden"
                   id="CategoryId"
                   name="CategoryId"
                   value="@Model.CategoryId" />

           <partial name="/Pages/Categories/_CategoryFilterPartial.cshtml"
                     model="Model.Categories"
                     view-data="ViewData" />

            <partial name="_PriceFilterPartial" model="Model" />
            
        </aside>

        <!-- Main -->
        <div class="col-lg-9">

            <partial name="_SortByPartial" model="Model" />

            <div class="row g-4">

                <partial name="_ProductListPartial" model="Model" />
                <partial name="_PaginationPartial" model="Model" />

            </div>

        </div>
    </div>
</div>