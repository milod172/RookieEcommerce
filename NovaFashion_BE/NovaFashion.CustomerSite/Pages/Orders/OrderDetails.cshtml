@page "/order-details/{id:Guid}"
@model NovaFashion.CustomerSite.Pages.Orders.OrderDetailsModel
@{
}

<div class="container pb-5 mt-5">

    <div class="order-details-header">
        <div>
            <h2 class="order-details-title serif">Chi tiết đơn hàng</h2>
            <div class="order-details-id">MÃ ĐƠN: #@Model.Order.Id</div>
        </div>
    </div>

    <div class="row g-4">

        <!-- LEFT -->
        <div class="col-lg-7">

            <!-- CUSTOMER -->
            <div class="order-details-section-title">Thông tin khách hàng</div>

            <div class="order-details-card">

                <div class="row g-3">

                    <div class="col-md-6">
                        <div class="order-details-label">Họ và tên</div>
                        <div class="order-details-value">@Model.Order.FullName</div>
                    </div>

                    <div class="col-md-6">
                        <div class="order-details-label">Số điện thoại</div>
                        <div class="order-details-value">@Model.Order.PhoneNumber</div>
                    </div>

                    <div class="col-md-12">
                        <div class="order-details-label">Địa chỉ giao hàng</div>
                        <div class="order-details-value">
                            @Model.Order.Address
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="order-details-label">Ngày tạo</div>
                        <div class="order-details-value">@Model.Order.CreateTime</div>
                    </div>

                </div>

            </div>

            <!-- PAYMENT -->
            <div class="order-details-section-title mt-4">Thông tin thanh toán</div>

            <div class="order-details-card">

                <div class="row g-3">

                    <div class="col-md-6">
                        <div class="order-details-label">Phương thức</div>
                        <div class="order-details-value">@Model.Order.PaymentMethod</div>
                    </div>

                    <div class="col-md-6">
                        <div class="order-details-label">Trạng thái</div>
                        <div class="order-details-value">
                            <span class="order-details-status-pill order-details-pill-paid">
                                @Model.Order.OrderStatus
                            </span>
                        </div>
                    </div>

                </div>

            </div>

            <div class="d-flex gap-2 mt-4 flex-wrap">
                <a asp-page="/Orders/OrdersList" class="order-details-btn-outline text-decoration-none">
                    QUAY LẠI DANH SÁCH
                </a>
            </div>

        </div>

        <!-- RIGHT -->
        <div class="col-lg-5">

            <div class="order-details-items-panel">
                <div class="order-details-items-title">
                    SẢN PHẨM ĐÃ ĐẶT (@Model.Order.OrderItems.Count())
                </div>

                @foreach(var item in Model.Order.OrderItems)
                {

                    <!-- ITEM -->
                    <div class="order-details-product-row">

                        <a asp-page="/Products/ProductDetails" asp-route-id="@item.ProductId">
                            <img src="@item.ImageUrl" alt="@item.ProductName">
                        </a>
                       

                        <div>

                            <div class="order-details-product-brand">@item.ProductName</div>

                            <div class="order-details-product-name">
                                @item.ProductDescription
                            </div>

                            <div class="order-details-product-meta">
                                 Size: @item.Size · Sl: @item.Quantity
                            </div>

                            <div class="order-details-product-price">
                                @item.TotalPrice.ToString("N0") ₫
                            </div>

                        </div>

                    </div>
                }
                
                <!-- TOTALS -->
                <div class="order-details-total-row order-details-grand-total">
                    <span>TỔNG CỘNG</span>
                    <span>@Model.Order.TotalAmount.ToString("N0") ₫</span>
                </div>

            </div>

        </div>

    </div>

   
    @if (Model.Rating != null){
        <div class="order-details__review-card mt-5">
            <div class="order-details__review-header">
                <h6 class="order-details__review-title">Đánh giá của bạn</h6>
                <span class="order-details__review-badge">
                    <i class="fa-solid fa-circle-check"></i>Đã gửi
                </span>
            </div>

            <div class="order-details__review-stars"
                 aria-label="@Model.Rating.Rate trên 5 sao">

                @for (int i = 1; i <= 5; i++)
                {
                    if (i <= Model.Rating.Rate)
                    {
                        <i class="fa-solid fa-star"></i>
                    }
                    else
                    {
                        <i class="fa-regular fa-star"></i>
                    }
                }

                <span class="order-details__review-score">
                    @Model.Rating.Rate
                </span>
            </div>

            <p class="order-details__review-comment">@Model.Rating.Comment</p>

            <div class="order-details__review-meta">
                <i class="fa-regular fa-clock"></i>Đánh giá vào @Model.Rating.RatingDate
            </div>
        </div>
    }else{
        <div class="order-details__rating-section">
            <h3 class="order-details__rating-title">Đánh giá sản phẩm</h3>

            <form method="post" class="order-details__rating-form" id="orderDetailsRatingForm">
                <div class="mb-3">
                    <div class="order-details__rating-stars"
                         id="orderDetailsRatingStars"
                         role="radiogroup"
                         aria-label="Chọn số sao">

                        <i class="fa-solid fa-star order-details__rating-star"
                           data-value="1"
                           role="radio"
                           aria-checked="false"></i>

                        <i class="fa-solid fa-star order-details__rating-star"
                           data-value="2"
                           role="radio"
                           aria-checked="false"></i>

                        <i class="fa-solid fa-star order-details__rating-star"
                           data-value="3"
                           role="radio"
                           aria-checked="false"></i>

                        <i class="fa-solid fa-star order-details__rating-star"
                           data-value="4"
                           role="radio"
                           aria-checked="false"></i>

                        <i class="fa-solid fa-star order-details__rating-star"
                           data-value="5"
                           role="radio"
                           aria-checked="false"></i>
                    </div>

                    <input type="hidden"
                           asp-for="Request.Rate"
                           id="orderDetailsRatingValue"
                           value="0">

                    <span asp-validation-for="Request.Rate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="orderDetailsRatingComment" class="order-details__rating-label">Nhận xét</label>
                    <textarea class="form-control order-details__rating-comment"
                              id="orderDetailsRatingComment"
                              asp-for="Request.Comment"
                              rows="4"
                              placeholder="Chia sẻ cảm nhận của bạn về sản phẩm..."></textarea>

                    <span asp-validation-for="Request.Comment" class="text-danger"></span>
                </div>

                <input type="hidden"
                           asp-for="Request.OrderId"
                           value="@Model.Order.Id">

                <button type="submit" class="order-details__rating-submit">Gửi đánh giá</button>
            </form>
        </div>
    }


</div>

<script>
    (() => {
        const stars = document.querySelectorAll('.order-details__rating-star');
        const input = document.getElementById('orderDetailsRatingValue');

        let selected = 0;

        function paint(rating) {
            stars.forEach(star => {
                const value = Number(star.dataset.value);
                star.classList.toggle('is-active', value <= rating);
            });
        }

        stars.forEach(star => {

            star.addEventListener('mouseenter', () => {
                paint(Number(star.dataset.value));
            });

            star.addEventListener('click', () => {
                selected = Number(star.dataset.value);
                input.value = selected;
                paint(selected);
            });
        });

        document.getElementById('orderDetailsRatingStars')
            .addEventListener('mouseleave', () => {
                paint(selected);
            });

    })();
</script>